# Server Configuration
PORT=5000
NODE_ENV=development
SITE_URL=http://localhost:5000

# MongoDB Local Configuration
# For local development, MongoDB should be running on localhost:27017
MONGO_URL=mongodb://localhost:27017/todo_ai_db
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=todo_ai_db

# Note: For local MongoDB (no authentication needed), leave these empty
MONGO_USER=
MONGO_PWD=

# For MongoDB Atlas (cloud), use these:
# MONGO_USER=your_username
# MONGO_PWD=your_password

# JWT Configuration
JWT_SECRET=todo_ai_secret_key_12345!@#$%
JWT_EXPIRY=7d

# Email Configuration (Optional for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@todoai.com

# Swagger API Documentation Configuration
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin@123

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# API Configuration
API_VERSION=v1

# Agentic AI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith Tracing Configuration (for LangGraph endpoint)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=todo-ai-langgraph
